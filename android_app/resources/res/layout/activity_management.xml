<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:test="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rel_main"
    android:background="@drawable/ic_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:background="#40ffffff"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <RelativeLayout
            android:id="@+id/lin_back"
            android:background="#00000000"
            android:layout_width="90dp"
            android:layout_height="50dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="20dp"
                android:layout_marginLeft="10dp"
                android:src="@drawable/ic_back_u"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="20dp"
            android:textColor="#ffffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/management"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rel_add"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/relativeLayout1"
        android:layout_alignParentLeft="true">
        <TextView
            android:textSize="25dp"
            android:textColor="#ffffffff"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:text="@string/add"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <ImageView
            android:background="@drawable/ic_add"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/linearLayout1"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rel_add"
        android:layout_alignParentLeft="true"/>
    <ExpandableListView
        android:id="@+id/management_list"
        android:background="#50000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:groupIndicator="@null"
        android:childDivider="#00000000"
        android:divider="#00000000"
        android:dividerHeight="1sp"
        android:layout_below="@+id/linearLayout1"
        android:layout_alignParentLeft="true"/>
</RelativeLayout>
