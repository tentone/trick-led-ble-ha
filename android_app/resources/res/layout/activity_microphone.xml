<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/lin_phone_mic"
        android:background="@drawable/btn_rec_bg"
        android:visibility="invisible"
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true">
        <TextView
            android:textColor="#ff000000"
            android:gravity="center"
            android:id="@+id/tv_shouji"
            android:background="@drawable/btn_selectrec_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/rmod5"
            android:layout_weight="1"/>
        <TextView
            android:textColor="#ff000000"
            android:gravity="center"
            android:id="@+id/tv_waim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/rmod6"
            android:layout_weight="1"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/wave1"
        android:background="@drawable/ic_circle4"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="70dp"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/wave2"
        android:background="@drawable/ic_circle4"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="70dp"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/wave3"
        android:background="@drawable/ic_circle4"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="70dp"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/btn"
        android:background="@drawable/ic_microphone"
        android:layout_width="60dp"
        android:layout_height="95dp"
        android:layout_marginTop="150dp"
        android:layout_centerHorizontal="true"/>
    <com.android.soundrecorder.VUMeter
        android:id="@+id/uvMeter"
        android:layout_width="200px"
        android:layout_height="80px"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/lin_rmod"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="40dp"
        android:layout_marginRight="40dp"
        android:layout_above="@+id/rel_speed">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textColor="#ff000000"
                android:gravity="center"
                android:id="@+id/tv_mod1"
                android:background="@drawable/btn_select_mod_bg"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="@string/rmod1"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textColor="#ff000000"
                android:gravity="center"
                android:id="@+id/tv_mod2"
                android:background="@drawable/btn_unselect_mod_bg"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="@string/rmod3"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rel_speed"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="120dp"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/linearLayout1"
            android:background="#40ffffff"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>
        <TextView
            android:textSize="24dp"
            android:id="@+id/imageView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="31dp"
            android:text="-"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="24dp"
            android:id="@+id/imageView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="25dp"
            android:text="+"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <SeekBar
            android:id="@+id/seekbar_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="55dp"
            android:layout_marginRight="60dp"
            android:maxHeight="4dp"
            android:max="60"
            android:progress="30"
            android:progressDrawable="@drawable/seekbar_style"
            android:minHeight="4dp"
            android:thumb="@drawable/ic_seekbar_btn"
            android:thumbOffset="1dp"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</RelativeLayout>
