<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:test="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="#0000ffff"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="0.7">
        <com.qh.ui.CircularSeekBar
            android:id="@+id/mCircularSeekBar"
            android:background="#00ffff00"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_marginLeft="1dp"
            android:layout_marginRight="1dp"
            android:layout_centerInParent="true"/>
        <TextView
            android:textSize="42dp"
            android:textStyle="bold"
            android:textColor="#ffffffff"
            android:gravity="center"
            android:id="@+id/tv_pro"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="50%"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <RelativeLayout
            android:id="@+id/rel_brightness"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="18dp"
            android:layout_alignParentLeft="true">
            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginLeft="31dp"
                android:src="@drawable/ic_msun"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginRight="25dp"
                android:src="@drawable/ic_bsun"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <SeekBar
                android:id="@+id/seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="55dp"
                android:layout_marginRight="60dp"
                android:maxHeight="6dp"
                android:progress="50"
                android:progressDrawable="@drawable/seekbar_style"
                android:minHeight="6dp"
                android:thumb="@drawable/ic_seekbar_btn"
                android:thumbOffset="1dp"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/lin_colors1"
            android:background="#00000000"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="90dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentBottom="true">
            <TextView
                android:textSize="@dimen/text_size1"
                android:textColor="#ffffffff"
                android:gravity="center"
                android:id="@+id/textView1"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:text="@string/classic"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re1"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="4dp"
                android:layout_toRightOf="@+id/textView1"
                android:layout_centerVertical="true">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color1"
                    android:background="@drawable/btn_wwbg1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:text="100%"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="4dp"/>
                <ImageView
                    android:id="@+id/ic_hook1"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re2"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="6dp"
                android:layout_toRightOf="@+id/re1"
                android:layout_alignTop="@+id/re1">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color2"
                    android:background="@drawable/btn_wwbg2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:text="75%"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/ic_hook2"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re3"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="6dp"
                android:layout_toRightOf="@+id/re2"
                android:layout_alignTop="@+id/re2">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color3"
                    android:background="@drawable/btn_wwbg3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:text="50%"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/ic_hook3"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re4"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="6dp"
                android:layout_toRightOf="@+id/re3"
                android:layout_alignTop="@+id/re3">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color4"
                    android:background="@drawable/btn_wwbg4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:text="25%"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/ic_hook4"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re5"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="6dp"
                android:layout_toRightOf="@+id/re4"
                android:layout_alignTop="@+id/re4">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color5"
                    android:background="@drawable/btn_wwbg5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:text="10%"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/ic_hook5"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center_vertical"
                android:id="@+id/re6"
                android:background="#00000000"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="6dp"
                android:layout_toRightOf="@+id/re5"
                android:layout_alignTop="@+id/re5">
                <TextView
                    android:textColor="#ff000000"
                    android:gravity="center"
                    android:id="@+id/img_color6"
                    android:background="@drawable/btn_wwbg6"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:text="5%"
                    android:layout_centerVertical="true"/>
                <ImageView
                    android:id="@+id/ic_hook6"
                    android:background="@drawable/ic_hook"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"/>
            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>
