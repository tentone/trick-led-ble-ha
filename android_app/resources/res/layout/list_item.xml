<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:minHeight="45dp">
    <ImageView
        android:id="@+id/img_conn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="14dp"
        android:src="@drawable/disconnectbutton"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <ProgressBar
        android:id="@+id/pb_conn"
        android:padding="2dp"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="10dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <ImageView
        android:id="@+id/img_child_light"
        android:padding="0dp"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/ic_light_u"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="14dp"
        android:textColor="#ffffffff"
        android:id="@+id/light_name"
        android:layout_width="130dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="1dp"
        android:text="light"
        android:layout_toRightOf="@+id/img_child_light"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:background="#40ffffff"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="1dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
