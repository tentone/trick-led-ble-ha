<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:minHeight="45dp">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/linearLayout1"
        android:background="#40ffffff"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="1dp"
        android:layout_alignParentBottom="true"/>
    <ImageView
        android:id="@+id/light_img"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="17dp"
        android:src="@drawable/ic_move_n"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <ImageView
        android:textSize="18dp"
        android:id="@+id/item_resetname"
        android:padding="10dp"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginRight="9dp"
        android:src="@drawable/ic_banshou"
        android:layout_toLeftOf="@+id/light_img"
        android:layout_centerVertical="true"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tx_delete"
        android:background="#ffff0000"
        android:visibility="gone"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:text="@string/delete"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="20dp"
        android:textColor="#ffffffff"
        android:id="@+id/light_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="22dp"
        android:text="@string/light"
        android:layout_toRightOf="@+id/tx_delete"
        android:layout_centerVertical="true"/>
</RelativeLayout>
