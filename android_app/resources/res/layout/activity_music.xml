<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/r1"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="16dp"
            android:textColor="#7fffffff"
            android:gravity="center"
            android:id="@+id/tx_album"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="------------------"
            android:layout_below="@+id/tx_music_name"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="22dp"
            android:textColor="#ffffffff"
            android:ellipsize="marquee"
            android:gravity="center"
            android:id="@+id/tx_music_name"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="----------"
            android:singleLine="true"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:marqueeRepeatLimit="marquee_forever"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="1dp"
        android:layout_below="@+id/r1"
        android:layout_alignParentLeft="true">
        <ImageView
            android:id="@+id/img_hop"
            android:padding="16dp"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginLeft="6dp"
            android:src="@drawable/ic_hop_n"/>
        <ImageView
            android:id="@+id/img_play"
            android:background="@drawable/ic_muisc_stop"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/img_play_last"
            android:background="@drawable/ic_play_last"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginRight="40dp"
            android:layout_toLeftOf="@+id/img_play"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/img_play_next"
            android:background="@drawable/ic_play_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="40dp"
            android:layout_toRightOf="@+id/img_play"
            android:layout_alignTop="@+id/img_play_last"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/lin_c"
            android:background="#ffff0000"
            android:visibility="gone"
            android:layout_width="32dp"
            android:layout_height="32dp"/>
        <ImageView
            android:id="@+id/img_mucis_mod"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginRight="20dp"
            android:src="@drawable/ic_playsequence"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/lin_waveform"
            android:background="#00000000"
            android:visibility="gone"
            android:layout_width="60dp"
            android:layout_height="50dp"
            android:layout_marginLeft="5dp"
            android:layout_toRightOf="@+id/img_play_next"
            android:layout_alignTop="@+id/img_play"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/re44"
        android:background="#00000000"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@+id/relativeLayout1"
        android:layout_alignParentLeft="true">
        <TextView
            android:textSize="10dp"
            android:textColor="#ffaeaeae"
            android:id="@+id/tx_statrtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="00:00"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="10dp"
            android:textColor="#ffaeaeae"
            android:id="@+id/tx_endtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="17dp"
            android:text="05:23"
            android:layout_alignBaseline="@+id/tx_statrtime"
            android:layout_alignBottom="@+id/tx_statrtime"
            android:layout_alignParentRight="true"/>
        <SeekBar
            android:id="@+id/seekbar_play"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="55dp"
            android:layout_marginRight="60dp"
            android:maxHeight="3dp"
            android:progress="100"
            android:progressDrawable="@drawable/play_seekbar_style"
            android:minHeight="3dp"
            android:thumb="@drawable/ic_seekbar_play_btn"
            android:thumbOffset="1dp"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:background="#40ffffff"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <ListView
        android:id="@+id/play_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="64dp"
        android:divider="#33ffffff"
        android:dividerHeight="0.5dp"
        android:layout_below="@+id/re44"
        android:layout_alignParentLeft="true"/>
</RelativeLayout>
